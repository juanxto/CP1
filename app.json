        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.joaovictor087.CP1"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "a6be4a1e-df51-46b4-b98b-53b267a9d9b6"
      }
    }
